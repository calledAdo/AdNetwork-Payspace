{
  "name": "payspace3-gateway",
  "version": "1.0.0",
  "description": "Per-block Express gateway — A2A routing, agent card serving, agent lifecycle management",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/sync_agent_templates.mjs",
    "start": "node dist/index.js",
    "start:local": "node scripts/run_gateway_local.mjs",
    "openclaw:gateway": "node scripts/openclaw_local.mjs gateway run --force",
    "openclaw:health": "node scripts/openclaw_local.mjs gateway health",
    "test:a2a": "npx tsx scripts/test_spawn_and_a2a.ts",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@ckb-ccc/core": "^1.12.5",
    "@noble/curves": "^2.0.1",
    "@playwright/mcp": "latest",
    "chokidar": "5.0.0",
    "express": "^5.2.1",
    "uuid": "13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
