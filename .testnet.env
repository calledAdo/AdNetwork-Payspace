# CKB Testnet Wallet — generated 2026-03-21
# Fund this address at https://faucet.nervos.org/
#
# Copy to repo-root .env for local dev:
#   cp .testnet.env .env
#
# After minting your testnet xUDT, set DEFAULT_XUDT_TYPE_ARGS (setup.sh merges it automatically).
# xUDT script metadata is resolved at runtime via CCC KnownScript — not stored here.
# BookingSpace + settlement lock cells: see packages/ckb_payspace_mcp/src/constants.ts (not env).

CKB_PRIVATE_KEY=d9d8ed1b72994ee895eb148e303771a77a60df9624cf00a4345dbc41bb6b6c80
CKB_PUBLIC_KEY=0x03ea46b13fdcf33865cb990a98a3e8f82a8c51ab77bd048c2b1093382ce24e235f
CKB_LOCK_ARGS=0x6fef11b3c4b63b14f0b9b5408bcb15e4ad8989e0
