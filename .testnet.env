# MCP
CKB_RPC_URL=https://testnet.ckb.dev/rpc
CKB_INDEXER_URL=https://testnet.ckb.dev/indexer
PORT=3000

# OpenClaw / LLM (required by ./scripts/setup.sh validation)
# OPENAI_BASE_URL — OpenAI-compatible API base URL (required at runtime; if set, init_openclaw_workspace.mjs adds share-ai:default to auth-profiles.json for the default primary model share-ai/...).
# OPENAI_API_KEY or OPENAI_KEY — API key for the API at OPENAI_BASE_URL (same credential used for openai:default and share-ai:default profiles).
# OPENAI_API_KEY=
# OPENAI_KEY=
# OPENAI_BASE_URL=

# xUDT token instance (hex type args) — fill after ./scripts/deploy-xudt or setup mint:
# DEFAULT_XUDT_TYPE_ARGS=0x...

# Runtime dirs at repo root
# AGENTS_DIR=./agent-workspaces
# OPENCLAW_STATE_DIR=./.openclaw
# OPENCLAW_CONFIG_PATH=./.openclaw/openclaw.json
# PLAYWRIGHT_OUTPUT_DIR=./playwright-output
